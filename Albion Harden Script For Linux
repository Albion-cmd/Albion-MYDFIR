# ── Colours ───────────────────────────────────────────────────────────────────
RED='\033[0;31m';      LRED='\033[1;31m'
GREEN='\033[0;32m';    LGREEN='\033[1;32m'
YELLOW='\033[1;33m';   CYAN='\033[0;36m'
LCYAN='\033[1;36m';    MAGENTA='\033[0;35m'
