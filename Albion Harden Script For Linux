apply_custom() {
    CHOICES=$(whiptail --title "[ ALBION HARDENER ] Custom Module Selection" \
        --checklist \
        "SPACE to select  |  ENTER to confirm\nSelect the modules you want to apply:" \
        30 72 12 \
        "update"      "System update & full upgrade"                  OFF \
        "firewall"    "Firewall setup (UFW / firewalld)"              OFF \
        "ssh"         "SSH hardening (no root, key-only, retries)"    OFF \
        "nonroot"     "Create non-root admin user"                    OFF \
        "services"    "Disable unnecessary services"                  OFF \
        "sysctl"      "Kernel hardening via sysctl"                   OFF \
        "mac"         "MAC address randomisation"                     OFF \
        "fail2ban"    "fail2ban brute-force protection"               OFF \
        "autoupdate"  "Automatic security updates"                    OFF \
        "rkhunter"    "Rootkit detection (rkhunter)"                  OFF \
        "password"    "Password complexity policy"                    OFF \
        "auditd"      "System audit logging (auditd)"                 OFF \
        3>&1 1>&2 2>&3)

    [ -z "$CHOICES" ] && whiptail --msgbox "No modules selected. Returning to menu." 8 50 && return

    print_banner
    type_text "  [CUSTOM] Applying selected modules..." "$LMAGENTA"
    sleep 1

    [[ "$CHOICES" == *"update"*     ]] && module_update
    [[ "$CHOICES" == *"firewall"*   ]] && module_firewall
    [[ "$CHOICES" == *"ssh"*        ]] && module_ssh
    [[ "$CHOICES" == *"nonroot"*    ]] && module_nonroot_user
    [[ "$CHOICES" == *"services"*   ]] && module_disable_services
    [[ "$CHOICES" == *"sysctl"*     ]] && module_sysctl
    [[ "$CHOICES" == *"mac"*        ]] && module_mac_spoof
    [[ "$CHOICES" == *"fail2ban"*   ]] && module_fail2ban
    [[ "$CHOICES" == *"autoupdate"* ]] && module_auto_updates
    [[ "$CHOICES" == *"rkhunter"*   ]] && module_rkhunter
    [[ "$CHOICES" == *"password"*   ]] && module_password_policy
    [[ "$CHOICES" == *"auditd"*     ]] && module_audit_log
}

# ═════════════════════════════════════════════════════════════════════════════
#  GUI SCREENS
# ═════════════════════════════════════════════════════════════════════════════
show_posture_report() {
    # Score bar
    BARS=$((SCORE / 5))
    BAR_FILLED=$(printf '█%.0s' $(seq 1 $BARS))
    BAR_EMPTY=$(printf '░%.0s'  $(seq 1 $((20 - BARS))))
    SCORE_BAR="${BAR_FILLED}${BAR_EMPTY}"

    REPORT="┌─────────────────────────────────────────────────┐\n"
    REPORT+="│          ALBION HARDENER — POSTURE REPORT       │\n"
    REPORT+="└─────────────────────────────────────────────────┘\n\n"
    REPORT+=" System        : $DISTRO_NAME\n"
    REPORT+=" Pkg Manager   : $PKG_MGR\n"
    REPORT+=" Firewall      : $FIREWALL_STATUS\n"
    REPORT+=" Open Ports    : ${OPEN_PORTS:-None detected}\n"

    if [ ${#DANGEROUS_PORTS[@]} -gt 0 ]; then
        REPORT+=" Danger Ports  : ${DANGEROUS_PORTS[*]}\n"
    else
        REPORT+=" Danger Ports  : None\n"
    fi

    if [ ${#RUNNING_SERVICES[@]} -gt 0 ]; then
        REPORT+=" Risky Services: ${RUNNING_SERVICES[*]}\n"
    else
        REPORT+=" Risky Services: None\n"
    fi

    REPORT+="\n ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
    REPORT+=" SCORE  : [$SCORE_BAR] $SCORE/100\n"
    REPORT+=" RISK   : $RISK_LEVEL\n"
    REPORT+=" ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
    REPORT+=" FINDINGS:\n"
    for finding in "${FINDINGS[@]}"; do
        REPORT+="   >> $finding\n"
    done
    [ ${#FINDINGS[@]} -eq 0 ] && REPORT+="   No critical issues detected.\n"
    REPORT+="\n Log saved to: $LOGFILE"

    whiptail --title "[ ALBION HARDENER ] Security Posture Report" \
        --scrolltext --msgbox "$REPORT" 36 72
}

show_level_menu() {
    LEVEL=$(whiptail --title "[ ALBION HARDENER ] Select Hardening Level" \
        --menu \
"  Score: $SCORE/100   |   Risk: $RISK_LEVEL
  ─────────────────────────────────────────────────
  Choose your hardening configuration:" \
        24 72 5 \
        "1" "DECENT   >> Firewall, update, non-root user, services" \
        "2" "ADVANCED >> DECENT + SSH, kernel tweaks, MAC, fail2ban" \
        "3" "SECURED  >> ADVANCED + auto-updates, rkhunter, auditd" \
        "4" "CUSTOM   >> Build your own — pick modules individually" \
        "5" "EXIT     >> Quit without making changes" \
        3>&1 1>&2 2>&3)

    case $LEVEL in
        1) LEVEL_NAME="DECENT"   ;;
        2) LEVEL_NAME="ADVANCED" ;;
        3) LEVEL_NAME="SECURED"  ;;
        4) LEVEL_NAME="CUSTOM"   ;;
        5) whiptail --msgbox "No changes made.\n\nLog: $LOGFILE" 10 55; exit 0 ;;
        *) exit 0 ;;
    esac
}

show_confirmation() {
    case $LEVEL_NAME in
        DECENT)
            DESC="  > System update & upgrade\n  > UFW/firewalld firewall setup\n  > Non-root admin user creation\n  > Disable unnecessary services"
            ;;
        ADVANCED)
            DESC="  > Everything in DECENT, plus:\n  > SSH hardening (no root, key-only, retries)\n  > Kernel hardening (sysctl)\n  > MAC address randomisation\n  > fail2ban brute-force protection"
            ;;
        SECURED)
            DESC="  > Everything in ADVANCED, plus:\n  > Automatic security updates\n  > Rootkit detection (rkhunter)\n  > Password complexity policy\n  > System audit logging (auditd)"
            ;;
        CUSTOM)
            DESC="  > You will select individual modules\n  > from a checklist on the next screen."
            ;;
    esac

    whiptail --title "[ ALBION HARDENER ] Confirm: $LEVEL_NAME" \
        --yesno \
"  You selected: $LEVEL_NAME hardening\n\n\
  This will apply:\n$DESC\n\n\
  Config file backups will be saved automatically.\n\
  All changes logged to:\n  $LOGFILE\n\n\
  Proceed?" \
        24 68

    [ $? -ne 0 ] && whiptail --msgbox "Cancelled. No changes were made." 8 50 && exit 0
}

show_completion() {
    whiptail --title "[ ALBION HARDENER ] Mission Complete" \
        --msgbox \
"  ╔═══════════════════════════════════════════════╗
  ║    ALBION HARDENER — HARDENING COMPLETE       ║
  ╚═══════════════════════════════════════════════╝

  Level Applied : $LEVEL_NAME
  Log File      : $LOGFILE

  Next Steps:
  >> Reboot your system to apply all changes
  >> If SSH password auth was disabled —
     ensure your key is in place first
  >> Re-run this script after reboot to
     verify your new security score
  >> Run 'sudo rkhunter --check' periodically

  ─────────────────────────────────────────────────
  Albion Hardener v2.0 — by Wilson Elan
  github.com/Albion-cmd/Albion-MYDFIR
  ─────────────────────────────────────────────────" \
        24 60
}

# ═════════════════════════════════════════════════════════════════════════════
#  MAIN
# ═════════════════════════════════════════════════════════════════════════════
main() {
    print_banner
    sleep 1

    whiptail --title "[ ALBION HARDENER v2.0 ]" \
        --msgbox \
"  Welcome to Albion Hardener
  Security Posture Assessment & Hardening Framework
  ─────────────────────────────────────────────────
  Author  : Wilson Elan
  GitHub  : github.com/Albion-cmd/Albion-MYDFIR
  Supports: Debian / Ubuntu / Kali / Arch / Fedora
  ─────────────────────────────────────────────────

  This tool will:
    [1] Scan your system's current security posture
    [2] Show a risk report with all findings scored
    [3] Let you choose a hardening level to apply
    [4] Log every change made for your review

  Press OK to begin the scan." \
        22 65

    # Detect distro
    whiptail --infobox "  [*] Detecting system and package manager..." 6 55
    detect_distro
    sleep 1

    # Scan
    whiptail --infobox "  [*] Scanning security posture — please wait..." 6 55
    scan_host
    sleep 1

    # Report
    show_posture_report

    # Level selection
    show_level_menu

    # Confirm
    show_confirmation

    # Execute
    case $LEVEL_NAME in
        DECENT)   apply_decent   ;;
        ADVANCED) apply_advanced ;;
        SECURED)  apply_secured  ;;
        CUSTOM)   apply_custom   ;;
    esac

    # Done
    echo ""
    echo -e "${LGREEN}"
    cat << "EOF"
  ╔══════════════════════════════════════════╗
  ║   HARDENING SEQUENCE COMPLETE            ║
  ║   Albion Hardener v2.0 — Wilson Elan     ║
  ╚══════════════════════════════════════════╝
EOF
    echo -e "${NC}"

    show_completion
    log "Complete. Level: $LEVEL_NAME"
}

main
