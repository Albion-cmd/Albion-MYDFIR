LBLUE='\033[1;34m';    BOLD='\033[1m'
DIM='\033[2m';         NC='\033[0m'

# ── Log file ──────────────────────────────────────────────────────────────────
LOGFILE="/var/log/albion_hardener_$(date +%Y%m%d_%H%M%S).log"
touch "$LOGFILE" 2>/dev/null || LOGFILE="/tmp/albion_hardener_$(date +%Y%m%d_%H%M%S).log"
log() { echo "[$(date '+%H:%M:%S')] $1" >> "$LOGFILE"; }

# ── Root check ────────────────────────────────────────────────────────────────
if [[ $EUID -ne 0 ]]; then
    echo -e "${LRED}[!] This script must be run as root. Use: sudo bash $0${NC}"
    exit 1
fi

# ── Dependency check ──────────────────────────────────────────────────────────
if ! command -v whiptail &>/dev/null; then
    echo -e "${YELLOW}[*] Installing whiptail...${NC}"
    apt install whiptail -y 2>/dev/null || \
    pacman -S libnewt --noconfirm 2>/dev/null || \
    dnf install newt -y 2>/dev/null
fi

