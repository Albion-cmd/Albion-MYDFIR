# ═════════════════════════════════════════════════════════════════════════════
#  PHASE 1 — DISTRO DETECTION
# ═════════════════════════════════════════════════════════════════════════════
detect_distro() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        DISTRO_NAME="$NAME"
        DISTRO_ID="${ID,,}"
    else
        DISTRO_NAME="Unknown"; DISTRO_ID="unknown"
    fi

    if   command -v apt     &>/dev/null; then PKG_MGR="apt";    PKG_INSTALL="apt install -y";           PKG_UPDATE="apt update && apt full-upgrade -y"
    elif command -v pacman  &>/dev/null; then PKG_MGR="pacman"; PKG_INSTALL="pacman -S --noconfirm";    PKG_UPDATE="pacman -Syu --noconfirm"
    elif command -v dnf     &>/dev/null; then PKG_MGR="dnf";    PKG_INSTALL="dnf install -y";           PKG_UPDATE="dnf upgrade -y"
    elif command -v yum     &>/dev/null; then PKG_MGR="yum";    PKG_INSTALL="yum install -y";           PKG_UPDATE="yum update -y"
    else                                      PKG_MGR="unknown";PKG_INSTALL="echo [!] Cannot install:"; PKG_UPDATE="echo [!] Cannot update"
    fi
    log "Distro: $DISTRO_NAME | PKG: $PKG_MGR"
}

# ═════════════════════════════════════════════════════════════════════════════
#  PHASE 2 — SECURITY POSTURE SCAN
# ═════════════════════════════════════════════════════════════════════════════
SCORE=100
FINDINGS=()
RISK_LEVEL=""

deduct() { SCORE=$((SCORE - $1)); }

scan_host() {
    log "Starting posture scan..."

    # Firewall
    if command -v ufw &>/dev/null && ufw status | grep -q "Status: active"; then
        FIREWALL_STATUS="UFW Active"
    elif command -v firewall-cmd &>/dev/null && firewall-cmd --state 2>/dev/null | grep -q "running"; then
        FIREWALL_STATUS="firewalld Active"
    elif command -v iptables &>/dev/null && iptables -L INPUT 2>/dev/null | grep -qv "ACCEPT all"; then
        FIREWALL_STATUS="iptables rules present"
    else
        FIREWALL_STATUS="NONE DETECTED"
        FINDINGS+=("CRITICAL: No active firewall found"); deduct 25
    fi

    # SSH
    SSH_ISSUES=()
    if [ -f /etc/ssh/sshd_config ]; then
        SSH_RUNNING=true
        grep -qiE "^PermitRootLogin yes"       /etc/ssh/sshd_config && SSH_ISSUES+=("Root login enabled")         && FINDINGS+=("HIGH: SSH root login permitted")            && deduct 15
        grep -qiE "^PasswordAuthentication yes" /etc/ssh/sshd_config && SSH_ISSUES+=("Password auth enabled")     && FINDINGS+=("MEDIUM: SSH password authentication enabled") && deduct 10
        SSH_PORT=$(grep -iE "^Port " /etc/ssh/sshd_config | awk '{print $2}')
        [ -z "$SSH_PORT" ] && SSH_PORT="22"
        [ "$SSH_PORT" = "22" ] && SSH_ISSUES+=("Default port 22") && FINDINGS+=("LOW: SSH on default port 22") && deduct 5
    else
        SSH_RUNNING=false
    fi

    # Open / dangerous ports
    OPEN_PORTS=""
    DANGEROUS_PORTS=()
    DANGEROUS_LIST=(21 23 25 135 139 445 3389 5900 6379 27017)
    if command -v ss &>/dev/null; then
        OPEN_PORTS=$(ss -tlnp 2>/dev/null | awk 'NR>1{print $4}' | grep -oE '[0-9]+$' | sort -u | tr '\n' ' ')
    elif command -v netstat &>/dev/null; then
        OPEN_PORTS=$(netstat -tlnp 2>/dev/null | awk 'NR>2{print $4}' | grep -oE '[0-9]+$' | sort -u | tr '\n' ' ')
    fi
    for port in $OPEN_PORTS; do
        for danger in "${DANGEROUS_LIST[@]}"; do
            [ "$port" = "$danger" ] && DANGEROUS_PORTS+=("$port") && FINDINGS+=("CRITICAL: Dangerous port $port open") && deduct 10
        done
    done

    # Unnecessary services
    RUNNING_SERVICES=()
    for svc in bluetooth cups avahi-daemon rpcbind nfs-server telnet vsftpd; do
        systemctl is-active --quiet "$svc" 2>/dev/null && RUNNING_SERVICES+=("$svc") && FINDINGS+=("MEDIUM: Unnecessary service running — $svc") && deduct 5
    done

    # Root password
    ROOT_EMPTY=$(passwd -S root 2>/dev/null | grep -c "NP\|empty")
    [ "$ROOT_EMPTY" -gt 0 ] && FINDINGS+=("CRITICAL: Root has no password") && deduct 20

    # Auto updates
    if ! command -v unattended-upgrades &>/dev/null && ! systemctl is-active --quiet dnf-automatic 2>/dev/null; then
        FINDINGS+=("LOW: Automatic security updates not configured"); deduct 5
    fi

    # fail2ban
    if ! command -v fail2ban-client &>/dev/null; then
        FINDINGS+=("MEDIUM: fail2ban not installed"); deduct 5
    fi

    [ $SCORE -lt 0 ] && SCORE=0

    if   [ $SCORE -ge 80 ]; then RISK_LEVEL="LOW RISK"
    elif [ $SCORE -ge 60 ]; then RISK_LEVEL="MODERATE RISK"
    elif [ $SCORE -ge 40 ]; then RISK_LEVEL="HIGH RISK"
    else                         RISK_LEVEL="CRITICAL RISK"
    fi

    log "Score: $SCORE | Risk: $RISK_LEVEL"
}

# ═════════════════════════════════════════════════════════════════════════════
#  HARDENING MODULES
# ═════════════════════════════════════════════════════════════════════════════
module_update() {
    section_header "SYSTEM UPDATE"
    type_text "  Pulling latest packages and security patches..." "$LCYAN"
    eval "$PKG_UPDATE" >> "$LOGFILE" 2>&1
    status_ok "System updated successfully."
}

module_firewall() {
    section_header "FIREWALL CONFIGURATION"
    if [ "$PKG_MGR" = "apt" ] || [ "$PKG_MGR" = "pacman" ]; then
        $PKG_INSTALL ufw >> "$LOGFILE" 2>&1
        ufw default deny incoming  >> "$LOGFILE" 2>&1
        ufw default allow outgoing >> "$LOGFILE" 2>&1
        ufw allow ssh   >> "$LOGFILE" 2>&1
        ufw allow 80/tcp  >> "$LOGFILE" 2>&1
        ufw allow 443/tcp >> "$LOGFILE" 2>&1
        ufw --force enable >> "$LOGFILE" 2>&1
        [ "$PKG_MGR" = "pacman" ] && systemctl enable ufw >> "$LOGFILE" 2>&1
        status_ok "UFW enabled — deny all inbound except SSH, HTTP, HTTPS."
    elif [ "$PKG_MGR" = "dnf" ] || [ "$PKG_MGR" = "yum" ]; then
        $PKG_INSTALL firewalld >> "$LOGFILE" 2>&1
        systemctl enable --now firewalld >> "$LOGFILE" 2>&1
        firewall-cmd --set-default-zone=drop >> "$LOGFILE" 2>&1
        firewall-cmd --permanent --add-service={ssh,http,https} >> "$LOGFILE" 2>&1
        firewall-cmd --reload >> "$LOGFILE" 2>&1
        status_ok "firewalld configured — default zone: drop."
    fi
}

module_ssh() {
    section_header "SSH HARDENING"
    SSHD="/etc/ssh/sshd_config"
    cp "$SSHD" "${SSHD}.albion_bak_$(date +%Y%m%d)" 2>/dev/null
    sed -i 's/^#*PermitRootLogin.*/PermitRootLogin no/'          "$SSHD"
    sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication no/' "$SSHD"
    sed -i 's/^#*X11Forwarding.*/X11Forwarding no/'              "$SSHD"
    sed -i 's/^#*MaxAuthTries.*/MaxAuthTries 3/'                  "$SSHD"
    sed -i 's/^#*LoginGraceTime.*/LoginGraceTime 30/'             "$SSHD"
    grep -q "^AllowTcpForwarding"  "$SSHD" || echo "AllowTcpForwarding no"   >> "$SSHD"
    grep -q "^ClientAliveInterval" "$SSHD" || echo "ClientAliveInterval 300" >> "$SSHD"
    grep -q "^ClientAliveCountMax" "$SSHD" || echo "ClientAliveCountMax 2"   >> "$SSHD"
    systemctl restart sshd 2>/dev/null || systemctl restart ssh 2>/dev/null
    status_ok "SSH hardened — root login disabled, max 3 auth attempts."
    status_warn "Password auth disabled — ensure SSH keys are set before logging out!"
}

module_nonroot_user() {
    section_header "NON-ROOT USER CREATION"
    USERNAME=$(whiptail --inputbox \
        "Enter username for the new non-root admin account:" \
        10 60 "auditor" --title "[ ALBION HARDENER ] Create User" 3>&1 1>&2 2>&3)
    if [ -n "$USERNAME" ]; then
        if ! id "$USERNAME" &>/dev/null; then
            useradd -m -G sudo  -s /bin/bash "$USERNAME" 2>/dev/null || \
            useradd -m -G wheel -s /bin/bash "$USERNAME" 2>/dev/null
            echo -e "\n  ${LGREEN}[+]${NC} User '${BOLD}$USERNAME${NC}' created. Set a password now:"
            passwd "$USERNAME"
            log "User $USERNAME created."
        else
            status_warn "User '$USERNAME' already exists — skipping."
        fi
    fi
}

module_disable_services() {
    section_header "DISABLING UNNECESSARY SERVICES"
    DISABLED=()
    for svc in bluetooth cups avahi-daemon rpcbind nfs-server telnet vsftpd; do
        if systemctl is-active --quiet "$svc" 2>/dev/null; then
            systemctl stop    "$svc" >> "$LOGFILE" 2>&1
            systemctl disable "$svc" >> "$LOGFILE" 2>&1
            DISABLED+=("$svc")
            status_ok "Stopped & disabled: $svc"
        fi
    done
    [ ${#DISABLED[@]} -eq 0 ] && status_info "No unnecessary services were running."
}

module_sysctl() {
    section_header "KERNEL HARDENING (SYSCTL)"
    SYSCTL_CONF="/etc/sysctl.d/99-albion-hardener.conf"
    cat > "$SYSCTL_CONF" <<EOF
# Albion Hardener — Kernel Security Settings — Wilson Elan
net.ipv4.ip_forward = 0
net.ipv4.conf.all.accept_source_route = 0
net.ipv6.conf.all.accept_source_route = 0
net.ipv4.conf.all.accept_redirects = 0
net.ipv6.conf.all.accept_redirects = 0
net.ipv4.conf.all.send_redirects = 0
net.ipv4.tcp_syncookies = 1
net.ipv4.conf.all.log_martians = 1
net.ipv4.icmp_echo_ignore_broadcasts = 1
net.ipv4.tcp_rfc1337 = 1
fs.suid_dumpable = 0
kernel.dmesg_restrict = 1
kernel.yama.ptrace_scope = 1
kernel.randomize_va_space = 2
EOF
    sysctl -p "$SYSCTL_CONF" >> "$LOGFILE" 2>&1
    status_ok "Kernel hardening applied — ASLR, SYN cookies, ptrace restrictions active."
}

module_mac_spoof() {
    section_header "MAC ADDRESS RANDOMISATION"
    $PKG_INSTALL macchanger >> "$LOGFILE" 2>&1
    mkdir -p /etc/NetworkManager/conf.d/
    cat > /etc/NetworkManager/conf.d/albion-mac-randomize.conf <<EOF
# Albion Hardener — MAC Randomisation — Wilson Elan
[device]
wifi.scan-rand-mac-address=yes
[connection]
ethernet.cloned-mac-address=random
wifi.cloned-mac-address=random
EOF
    systemctl restart NetworkManager 2>/dev/null
    status_ok "MAC randomisation configured via NetworkManager (cross-distro)."
}

module_fail2ban() {
    section_header "FAIL2BAN — BRUTE FORCE PROTECTION"
    $PKG_INSTALL fail2ban >> "$LOGFILE" 2>&1
    cat > /etc/fail2ban/jail.local <<EOF
# Albion Hardener — fail2ban config — Wilson Elan
[DEFAULT]
bantime  = 3600
findtime = 600
maxretry = 3
backend  = systemd
[sshd]
enabled  = true
port     = ssh
logpath  = %(sshd_log)s
maxretry = 3
EOF
    systemctl enable --now fail2ban >> "$LOGFILE" 2>&1
    status_ok "fail2ban active — SSH brute force protection enabled (ban after 3 attempts)."
}

module_auto_updates() {
    section_header "AUTOMATIC SECURITY UPDATES"
    if [ "$PKG_MGR" = "apt" ]; then
        $PKG_INSTALL unattended-upgrades apt-listchanges >> "$LOGFILE" 2>&1
        dpkg-reconfigure -plow unattended-upgrades >> "$LOGFILE" 2>&1
        status_ok "Automatic security updates enabled (unattended-upgrades)."
    elif [ "$PKG_MGR" = "dnf" ]; then
        $PKG_INSTALL dnf-automatic >> "$LOGFILE" 2>&1
        sed -i 's/apply_updates = no/apply_updates = yes/' /etc/dnf/automatic.conf
        systemctl enable --now dnf-automatic.timer >> "$LOGFILE" 2>&1
        status_ok "Automatic updates enabled (dnf-automatic)."
    elif [ "$PKG_MGR" = "pacman" ]; then
        status_warn "Arch Linux does not support automatic updates — manual updates recommended."
    fi
}

module_rkhunter() {
    section_header "ROOTKIT DETECTION (RKHUNTER)"
    $PKG_INSTALL rkhunter >> "$LOGFILE" 2>&1
    rkhunter --update  >> "$LOGFILE" 2>&1
    rkhunter --propupd >> "$LOGFILE" 2>&1
    status_ok "rkhunter installed and database updated."
    status_info "Run 'sudo rkhunter --check' anytime to scan for rootkits."
}

module_password_policy() {
    section_header "PASSWORD COMPLEXITY POLICY"
    if [ "$PKG_MGR" = "apt" ]; then
        $PKG_INSTALL libpam-pwquality >> "$LOGFILE" 2>&1
        cat > /etc/security/pwquality.conf <<EOF
# Albion Hardener — Password Policy — Wilson Elan
minlen   = 12
minclass = 3
maxrepeat = 2
gecoscheck = 1
EOF
        status_ok "Password policy enforced — min 12 chars, 3 complexity classes required."
    else
        status_warn "Password policy skipped — configure manually for this distro."
    fi
}

module_audit_log() {
    section_header "SYSTEM AUDIT LOGGING (AUDITD)"
    $PKG_INSTALL auditd >> "$LOGFILE" 2>&1
    systemctl enable --now auditd >> "$LOGFILE" 2>&1
    status_ok "auditd installed and running — system activity now being recorded."
    status_info "View logs: sudo ausearch -m avc | tail -20"
}

